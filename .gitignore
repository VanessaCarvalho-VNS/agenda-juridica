# ============================================================
# AGENDA JURÍDICA — .gitignore (monorepo raiz)
# ============================================================

# ──────────────────────────────────────────
# Dependências
# ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ──────────────────────────────────────────
# Variáveis de ambiente (NUNCA commitar!)
# ──────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ──────────────────────────────────────────
# Build / dist
# ──────────────────────────────────────────
dist/
build/
out/
.vite/
.tsbuildinfo
*.tsbuildinfo

# ──────────────────────────────────────────
# Uploads de usuário (arquivos enviados em runtime)
# ──────────────────────────────────────────
backend/uploads/
!backend/uploads/.gitkeep

# ──────────────────────────────────────────
# WhatsApp Bot — sessão / autenticação local
# ──────────────────────────────────────────
whatsapp-bot/whatsapp/auth_info_baileys/
whatsapp-bot/whatsapp/store/

# ──────────────────────────────────────────
# Logs
# ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────────────────
# Cache / temporários
# ──────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.swp
*.swo
*~

# ──────────────────────────────────────────
# Cobertura de testes
# ──────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────
# IDEs e editores
# ──────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ──────────────────────────────────────────
# Sistema operacional
# ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────────────
# Docker / containers
# ──────────────────────────────────────────
.dockerignore

# ──────────────────────────────────────────
# Misc
# ──────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.jks
